# ─── N4B MSSQL bağlantısı ──────────────────────────────────────
TICKET_MSSQL_SERVER=10.135.140.17
TICKET_MSSQL_INSTANCE=yazdes
TICKET_MSSQL_PORT=1433
TICKET_MSSQL_DATABASE=N4B
TICKET_MSSQL_USER=
TICKET_MSSQL_PASSWORD=
TICKET_MSSQL_ENCRYPT=false
TICKET_MSSQL_TRUST_SERVER_CERT=true

# ─── App config ─────────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# Cache lokasyonu (mutlak yol veya app/server/'a göre relative)
CACHE_DB_PATH=./data/cache.sqlite

# Ingestor poll süresi (saniye)
INGESTOR_POLL_SECONDS=300

# İlk fetch'te geriye dönük kaç gün çekilsin
INGESTOR_BOOTSTRAP_DAYS=90

# CORS — frontend dev origin
WEB_ORIGIN=http://localhost:5173
